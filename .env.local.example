# Client-side GCS log viewer (/gcs) configuration.
# Copy to .env.local and fill in. These are NEXT_PUBLIC_* so they are readable in
# the browser — that is expected and safe (the OAuth Client ID is public; there
# is no client secret).

# OAuth 2.0 Client ID (Web application) from the GCP Console. See README for
# step-by-step setup. REQUIRED.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional defaults to pre-select the project/bucket pickers after sign-in.
# You can always switch project/bucket in the UI. The bucket dropdown only lists
# buckets whose name ends with "k8s_container_logs".
NEXT_PUBLIC_GCS_PROJECT=
NEXT_PUBLIC_GCS_LOG_BUCKET=krungthai_sag_dev_k8s_container_logs

# Max single-file download size in MB (default 50). Bigger files use more
# browser memory. Set to 0 to remove the limit entirely.
NEXT_PUBLIC_GCS_MAX_FILE_MB=50

# Max parsed log entries kept in memory across a load (default 100000). Bounds
# memory on huge files; narrow by hour/log/date to target a slice. 0 = keep all.
NEXT_PUBLIC_GCS_MAX_ENTRIES=100000
