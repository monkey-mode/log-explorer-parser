{
  "manifest_version": 3,
  "name": "Log Explorer",
  "version": "1.0.0",
  "description": "GCP-style log explorer for OpenSearch — query and investigate logs directly from your browser.",
  "permissions": ["sidePanel", "storage", "tabs", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "action": {
    "default_title": "Log Explorer"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "icons": {}
}
