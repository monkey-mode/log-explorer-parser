{
  "manifest_version": 3,
  "name": "Log Explorer — Cookie Bridge",
  "version": "1.0.0",
  "description": "Fetches logs from OSD in your browser and sends them to the Log Explorer web app.",
  "permissions": ["tabs", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send cookies to Log Explorer",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
