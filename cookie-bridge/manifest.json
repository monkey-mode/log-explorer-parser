{
  "manifest_version": 3,
  "name": "Log Explorer — Cookie Bridge",
  "version": "1.1.0",
  "description": "Fetches logs from OSD in your browser and sends them to the Log Explorer web app.",
  "permissions": ["tabs", "activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Send cookies to Log Explorer",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
